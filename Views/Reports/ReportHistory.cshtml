@model IEnumerable<GamblingBuddies.Models.PaymentReport>

@{
    ViewData["Title"] = "Historia raportów";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header" style="background-color: #8b0000; color: white;">
            <h3>Historia wygenerowanych raportów płatności</h3>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    Brak wygenerowanych raportów. Użyj formularza do wygenerowania pierwszego raportu.
                </div>
            }
            else
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Nazwa raportu</th>
                            <th>Data generowania</th>
                            <th>Okres</th>
                            <th>Liczba transakcji</th>
                            <th>Łączna kwota</th>
                            <th>Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var report in Model)
                        {
                            <tr>
                                <td>@report.ReportName</td>
                                <td>@report.GeneratedDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@report.StartDate?.ToShortDateString() - @report.EndDate?.ToShortDateString()</td>
                                <td>@report.TransactionsCount</td>
                                <td>@report.TotalAmount.ToString("C")</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@report.PaymentReportId" class="btn btn-info btn-sm">Szczegóły</a>
                                    <form asp-action="Delete" asp-route-id="@report.PaymentReportId" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Czy na pewno chcesz usunąć ten raport?')">Usuń</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            
            <div class="mt-3">
                <a asp-action="PaymentReport" class="btn btn-primary">Generuj nowy raport</a>
                <a asp-action="Index" class="btn btn-secondary">Powrót</a>
            </div>
        </div>
    </div>
</div>