@model GamblingBuddies.Models.PaymentReport

@{
    ViewData["Title"] = "Szczegóły raportu";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header" style="background-color: #8b0000; color: white;">
            <h3>Szczegóły raportu</h3>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Nazwa raportu</dt>
                <dd class="col-sm-9">@Model.ReportName</dd>

                <dt class="col-sm-3">Opis</dt>
                <dd class="col-sm-9">@Model.Description</dd>

                <dt class="col-sm-3">Data generowania</dt>
                <dd class="col-sm-9">@Model.GeneratedDate.ToString("yyyy-MM-dd HH:mm:ss")</dd>

                <dt class="col-sm-3">Okres od</dt>
                <dd class="col-sm-9">@(Model.StartDate?.ToShortDateString() ?? "Brak")</dd>

                <dt class="col-sm-3">Okres do</dt>
                <dd class="col-sm-9">@(Model.EndDate?.ToShortDateString() ?? "Brak")</dd>

                <dt class="col-sm-3">Liczba transakcji</dt>
                <dd class="col-sm-9">@Model.TransactionsCount</dd>

                <dt class="col-sm-3">Łączna kwota</dt>
                <dd class="col-sm-9">@Model.TotalAmount.ToString("C")</dd>

                <dt class="col-sm-3">Filtry</dt>
                <dd class="col-sm-9">@Model.FiltersApplied</dd>

                <dt class="col-sm-3">Wygenerował</dt>
                <dd class="col-sm-9">@(Model.GeneratedByUser?.Login ?? "Nieznany")</dd>
            </dl>

            <div class="mt-3">
                <a asp-action="ReportHistory" class="btn btn-secondary">Powrót do listy</a>
            </div>
        </div>
    </div>
</div>