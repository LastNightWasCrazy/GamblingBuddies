@model GamblingBuddies.Controllers.AssignmentFormViewModel

@{
    ViewData["Title"] = "Dodaj przypisanie pracownika";
}

<h2>Dodaj przypisanie pracownika do sesji</h2>

<form asp-action="CreateAssignment" method="post" autocomplete="off">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="EmployeeId" class="form-label">Pracownik</label>
        <select asp-for="EmployeeId" asp-items="ViewBag.Employees" class="form-select">
            <option value="">-- wybierz aktywnego pracownika --</option>
        </select>
        <span asp-validation-for="EmployeeId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="GameSessionId" class="form-label">Sesja gry</label>
        <select asp-for="GameSessionId" asp-items="ViewBag.GameSessions" class="form-select">
            <option value="">-- wybierz sesję --</option>
        </select>
        <span asp-validation-for="GameSessionId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Notes" class="form-label">Notatki</label>
        <textarea asp-for="Notes" class="form-control" maxlength="1000"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Zapisz</button>
    <a asp-action="Assignments" class="btn btn-secondary">Anuluj</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
