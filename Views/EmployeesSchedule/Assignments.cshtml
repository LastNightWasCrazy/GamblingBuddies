@model IEnumerable<GamblingBuddies.Models.EmployeeAssignment>

@{
    ViewData["Title"] = "Przypisania pracowników";
    bool isAdmin = User.IsInRole("Administrator");
    bool isAdminOrManager = User.IsInRole("Administrator") || User.IsInRole("Manager");
    bool onlyMine = ViewBag.OnlyMine == true;
    bool showInactive = ViewBag.ShowInactive == true;
}

<h2>Przypisania pracowników do sesji gry</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (isAdminOrManager)
{
    <div class="mb-3">
        <a asp-action="Assignments"
           asp-route-showInactive="@showInactive"
           class="btn btn-secondary">
            Pokaż wszystkie przypisania
        </a>

        <a asp-action="Assignments"
           asp-route-onlyMine="true"
           asp-route-showInactive="@showInactive"
           class="btn btn-primary">
            Pokaż tylko moje przypisania
        </a>

        <a asp-action="Assignments"
           asp-route-onlyMine="@onlyMine"
           asp-route-showInactive="@(!showInactive)"
           class="btn btn-warning">
            @(showInactive ? "Ukryj nieaktywnych" : "Pokaż też nieaktywnych")
        </a>

        <a asp-action="CreateAssignment" class="btn btn-success">
            Dodaj przypisanie
        </a>
    </div>
}

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Pracownik</th>
            <th>Status</th>
            <th>Stanowisko</th>
            <th>Gra</th>
            <th>Wariant</th>
            <th>Sala</th>
            <th>Stół</th>
            <th>Start</th>
            <th>Koniec</th>
            <th>Przypisał</th>
            <th>Notatki</th>
            @if (isAdmin)
            {
                <th>Akcje</th>
            }
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="@(isAdmin ? 12 : 11)" class="text-center">
                    Brak przypisań do wyświetlenia.
                </td>
            </tr>
        }
        else
        {
            foreach (var assignment in Model)
            {
                var employeeStatus = assignment.Employee?.Status?.Name ?? "Brak statusu";
                var rowClass = employeeStatus == "Inactive" ? "table-secondary" : "";

                <tr class="@rowClass">
                    <td>@assignment.Employee?.FirstName @assignment.Employee?.LastName</td>
                    <td>
                        @if (employeeStatus == "Inactive")
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                        else
                        {
                            <span class="badge bg-success">@employeeStatus</span>
                        }
                    </td>
                    <td>@(assignment.Employee?.Position?.Name ?? "-")</td>
                    <td>@(assignment.GameSession?.GameVariant?.Game?.Name ?? "-")</td>
                    <td>@(assignment.GameSession?.GameVariant?.Name ?? "-")</td>
                    <td>@(assignment.GameSession?.GameTable?.Hall?.Name ?? "-")</td>
                    <td>@(assignment.GameSession?.GameTable?.TableNumber.ToString() ?? "-")</td>
                    <td>@(assignment.GameSession?.StartAt.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                    <td>@(assignment.GameSession?.EndAt.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                    <td>@(assignment.AssignedByUser?.Login ?? "-")</td>
                    <td>@assignment.Notes</td>
                    @if (isAdmin)
                    {
                        <td>
                            <form asp-action="DeleteAssignment"
                                  asp-route-id="@assignment.EmployeeAssignmentId"
                                  method="post"
                                  style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-danger btn-sm"
                                        onclick="return confirm('Usunąć przypisanie?')">
                                    Usuń
                                </button>
                            </form>
                        </td>
                    }
                </tr>
            }
        }
    </tbody>
</table>

@if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @if (ViewBag.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Assignments" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-onlyMine="@onlyMine" asp-route-showInactive="@showInactive">«</a>
                </li>
            }

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Assignments" asp-route-page="@i" asp-route-onlyMine="@onlyMine" asp-route-showInactive="@showInactive">@i</a>
                </li>
            }

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Assignments" asp-route-page="@(ViewBag.CurrentPage + 1)" asp-route-onlyMine="@onlyMine" asp-route-showInactive="@showInactive">»</a>
                </li>
            }
        </ul>
    </nav>
}
