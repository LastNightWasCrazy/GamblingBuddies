@model IEnumerable<GamblingBuddies.Models.Reservation>

@{
    ViewData["Title"] = "Podgląd rezerwacji";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Podgląd rezerwacji</h1>
        <span class="badge bg-secondary fs-6">Panel administracyjny</span>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <table class="table table-dark table-striped table-hover align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Gracz</th>
                        <th>Sesja gry</th>
                        <th>Status rezerwacji</th>
                        <th>Status płatności</th>
                        <th>Data rezerwacji</th>
                        <th>Akcje</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var reservation in Model)
                    {
                        var latestPayment = reservation.Payments?
                        .OrderByDescending(p => p.CreatedAt)
                        .FirstOrDefault();

                        <tr>
                            <td>@reservation.ReservationId</td>

                            <td>
                                @reservation.Player?.FirstName @reservation.Player?.LastName
                            </td>

                            <td>
                                @reservation.GameSession?.GameVariant?.Name
                            </td>

                            <td>
                                @reservation.ReservationStatus?.Name
                            </td>

                            <td>
                                @(latestPayment?.PaymentStatus?.Name ?? "Brak płatności")
                            </td>

                            <td>
                                @reservation.ReservedAt.ToString("yyyy-MM-dd HH:mm")
                            </td>

                            <td>
                                <a class="btn btn-sm btn-primary"
                                   asp-controller="Reservations"
                                   asp-action="Details"
                                   asp-route-id="@reservation.ReservationId">
                                    Szczegóły
                                </a>

                                <a class="btn btn-sm btn-warning"
                                   asp-controller="Reservations"
                                   asp-action="Edit"
                                   asp-route-id="@reservation.ReservationId">
                                    Edytuj
                                </a>

                                <form asp-controller="Reservations"
                                      asp-action="Delete"
                                      asp-route-id="@reservation.ReservationId"
                                      method="post"
                                      style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Czy na pewno chcesz usunąć tę rezerwację?')">
                                        Usuń
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>
