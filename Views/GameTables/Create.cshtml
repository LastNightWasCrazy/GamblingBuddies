@model GamblingBuddies.Models.GameTable

@{
    ViewData["Title"] = "Dodawanie stołu";
}

<div class="container mt-4">
    <h1 class="mb-4">Dodaj stół</h1>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <form asp-controller="GameTables" asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="TableNumber" class="form-label">Numer stołu</label>
                    <input asp-for="TableNumber" class="form-control" />
                    <span asp-validation-for="TableNumber" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="HallId" class="form-label">Sala</label>
                    <select asp-for="HallId" asp-items="ViewBag.Halls" class="form-select">
                        <option value="">-- wybierz salę --</option>
                    </select>
                    <span asp-validation-for="HallId" class="text-danger"></span>
                </div>

                @using GamblingBuddies.Models

                <div class="mb-3">
                    <label class="form-label">Gry dostępne przy tym stole</label>

                    @{
                        var selectedGameIds = ViewBag.SelectedGameIds as int[] ?? Array.Empty<int>();
                        var games = ViewBag.Games as List<Game> ?? new List<Game>();
                    }

                    @foreach (var game in games)
                    {
                        var isChecked = selectedGameIds.Any(id => id == game.GameId);

                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="selectedGameIds"
                                   value="@game.GameId"
                                   @(isChecked ? "checked" : "") />

                            <label class="form-check-label">
                                @game.Name
                            </label>
                        </div>
                    }
                </div>

                <div class="mb-3">
                    <label asp-for="MinPlayers" class="form-label">Minimalna liczba graczy</label>
                    <input asp-for="MinPlayers" class="form-control" type="number" min="1" />
                    <span asp-validation-for="MinPlayers" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MaxPlayers" class="form-label">Maksymalna liczba graczy</label>
                    <input asp-for="MaxPlayers" class="form-control" type="number" min="1" />
                    <span asp-validation-for="MaxPlayers" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Aktywny</label>
                </div>

                <button type="submit" class="btn btn-success">
                    Dodaj stół
                </button>

                <a asp-controller="GameTables" asp-action="Index" class="btn btn-secondary">
                    Wróć
                </a>
            </form>

        </div>
    </div>
</div>