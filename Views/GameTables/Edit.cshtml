@model GamblingBuddies.Models.GameTable
@using GamblingBuddies.Models

@{
    ViewData["Title"] = "Edycja stołu";

    var games = ViewBag.Games as List<Game> ?? new List<Game>();
    var selectedGameIds = ViewBag.SelectedGameIds as int[] ?? Array.Empty<int>();
}

<div class="container mt-4">
    <h1 class="mb-4">Edycja stołu @Model.TableNumber</h1>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <form asp-controller="GameTables" asp-action="Edit" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="GameTableId" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="TableNumber" class="form-label">Numer stołu</label>
                    <input asp-for="TableNumber" class="form-control" />
                    <span asp-validation-for="TableNumber" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="HallId" class="form-label">Sala</label>
                    <select asp-for="HallId" asp-items="ViewBag.Halls" class="form-select"></select>
                    <span asp-validation-for="HallId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MinPlayers" class="form-label">Minimalna liczba graczy</label>
                    <input asp-for="MinPlayers" class="form-control" />
                    <span asp-validation-for="MinPlayers" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MaxPlayers" class="form-label">Maksymalna liczba graczy</label>
                    <input asp-for="MaxPlayers" class="form-control" />
                    <span asp-validation-for="MaxPlayers" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">Aktywny</label>
                </div>

                <div class="mb-4">
                    <label class="form-label">Gry dostępne przy tym stole</label>

                    @if (games.Any())
                    {
                        <div class="border rounded p-3">
                            @foreach (var game in games)
                            {
                                var isChecked = selectedGameIds.Any(id => id == game.GameId);

                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="selectedGameIds"
                                           value="@game.GameId"
                                           @(isChecked ? "checked" : "") />

                                    <label class="form-check-label">
                                        @game.Name
                                    </label>
                                </div>
                            }
                        </div>

                        <small class="text-muted">
                            Zaznaczone gry będą dostępne przy tym stole. Odznaczenie gry usuwa jej przypisanie.
                        </small>
                    }
                    else
                    {
                        <p class="text-muted mb-0">
                            Brak aktywnych gier do przypisania. Najpierw dodaj grę w panelu gier.
                        </p>
                    }
                </div>

                <button type="submit" class="btn btn-success">Zapisz zmiany</button>

                <a asp-controller="GameTables" asp-action="Details" asp-route-id="@Model.GameTableId" class="btn btn-info">
                    Szczegóły
                </a>

                <a asp-controller="GameTables" asp-action="Index" class="btn btn-secondary">
                    Wróć
                </a>
            </form>

        </div>
    </div>
</div>