@model GamblingBuddies.Models.GameTable
@using GamblingBuddies.Models

@{
    ViewData["Title"] = "Edycja stołu";
    var games = ViewBag.Games as List<Game> ?? new List<Game>();
    var selectedGameIds = ViewBag.SelectedGameIds as int[] ?? Array.Empty<int>();
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header" style="background-color: #8b0000; color: white;">
                    <h3 class="mb-0">Edycja stołu @Model.TableNumber</h3>
                </div>
                <div class="card-body">
                    <form asp-controller="GameTables" asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="GameTableId" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="TableNumber" class="form-label fw-bold">Numer stołu</label>
                            <input asp-for="TableNumber" class="form-control" type="number" min="1" />
                            <span asp-validation-for="TableNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="HallId" class="form-label fw-bold">Sala</label>
                            <select asp-for="HallId" asp-items="ViewBag.Halls" class="form-select">
                                <option value="">-- wybierz salę --</option>
                            </select>
                            <span asp-validation-for="HallId" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="MinPlayers" class="form-label fw-bold">Min. graczy</label>
                                <input asp-for="MinPlayers" class="form-control" type="number" min="1" />
                                <span asp-validation-for="MinPlayers" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="MaxPlayers" class="form-label fw-bold">Max. graczy</label>
                                <input asp-for="MaxPlayers" class="form-control" type="number" min="1" />
                                <span asp-validation-for="MaxPlayers" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-check mb-3">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label">Aktywny</label>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Gry dostępne przy tym stole</label>
                            @if (games.Any())
                            {
                                <div class="border rounded p-3" style="max-height: 250px; overflow-y: auto;">
                                    @foreach (var game in games)
                                    {
                                        var isChecked = selectedGameIds.Any(id => id == game.GameId);
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="selectedGameIds" value="@game.GameId" @(isChecked ? "checked" : "") />
                                            <label class="form-check-label">@game.Name</label>
                                        </div>
                                    }
                                </div>
                                <small class="text-muted">Zaznacz gry dostępne przy tym stole.</small>
                            }
                            else
                            {
                                <p class="text-muted mb-0">Brak aktywnych gier do przypisania.</p>
                            }
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Zapisz zmiany</button>
                            <a asp-action="Details" asp-route-id="@Model.GameTableId" class="btn btn-info">Szczegóły</a>
                            <a asp-action="Index" class="btn btn-secondary">Wróć</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}