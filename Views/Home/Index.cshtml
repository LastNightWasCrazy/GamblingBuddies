@{
    ViewData["Title"] = "Panel główny";
}

<div class="container-fluid">

    @if (User.IsInRole("Administrator") || User.IsInRole("Manager"))
    {
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card shadow-sm h-100 border-0">
                    <div class="card-body text-center">
                        <h5 class="card-title">Panel administracyjny</h5>
                        <p class="card-text">Zarządzanie systemem, stołami, sesjami i danymi administracyjnymi.</p>
                        <a asp-controller="AdminPanel" asp-action="Index" class="btn btn-dark">
                            Otwórz panel
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Fortuna już czeka!</h1>
    </div>

    <div class="MainDiv">

        <div class="DivAbout">
            <div class="card shadow-sm h-100 border-1">
                <div class="card-body text-start">
                    <h5 class="card-title me-auto">O nas</h5>
                    <div class="AboutDescription">
                        <p>
                            GamblingBuddies to system wspierający zarządzanie kasynem online,
                            rezerwacjami, grami, stołami oraz sesjami rozgrywek.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="DivReservation">
            <div class="card shadow-sm h-100 border-1">
                <div class="card-body text-start">
                    <h5 class="card-title">Masz ochotę na trochę prywatności?</h5>
                    <p class="card-text">Zarezerwuj miejsce przy stole i wybierz interesującą Cię sesję gry.</p>
                    <a asp-controller="Reservation" asp-action="Go" class="btnReservation">Rezerwacja</a>
                </div>
            </div>
        </div>

        <div class="DivGames">
            <div class="card text-start shadow-sm h-100 border-1">
                <div class="card-body text-center">
                    <h5 class="card-title">Gry</h5>
                    <p class="card-text">Oferta gier oraz warianty rozgrywek.</p>
                </div>

                <div class="divDescription">

                    <div class="cardGame">
                        <img src="/Images/poker.jpg" alt="Gry karciane">

                        <div class="cardText">
                            <h3>Gry karciane</h3>

                            <p>
                                Strategiczne gry stołowe oparte na układach kart,
                                analizie przeciwników i podejmowaniu decyzji.
                            </p>

                            <button class="btn btn-dark mt-2"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#cardGamesCollapse"
                                    aria-expanded="false"
                                    aria-controls="cardGamesCollapse">
                                Zobacz gry
                            </button>

                            <div class="collapse mt-3" id="cardGamesCollapse">
                                <div class="card card-body text-start text-light">

                                    <h5>Blackjack</h5>
                                    <p>
                                        Gra przeciwko krupierowi, której celem jest uzyskanie wyniku
                                        jak najbliższego 21 punktom bez przekroczenia tej wartości.
                                    </p>

                                    <h5>Poker</h5>
                                    <p>
                                        Gra strategiczna oparta na układach kart, blefie
                                        oraz analizie decyzji przeciwników.
                                    </p>

                                    <h5>Baccarat</h5>
                                    <p>
                                        Szybka gra karciana polegająca na obstawianiu wyniku
                                        rozdania gracza albo bankiera.
                                    </p>

                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="cardGame">
                        <img src="/Images/Ruletka.jpg" alt="Ruletka">

                        <div class="cardText">
                            <h3>Ruletka</h3>

                            <p>
                                Klasyczne gry losowe oparte na obstawianiu wyników
                                obrotu koła ruletki.
                            </p>

                            <button class="btn btn-danger mt-2"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#rouletteCollapse"
                                    aria-expanded="false"
                                    aria-controls="rouletteCollapse">
                                Zobacz gry
                            </button>

                            <div class="collapse mt-3" id="rouletteCollapse">
                                <div class="card card-body text-start text-light">

                                    <h5>Ruletka europejska</h5>
                                    <p>
                                        Tradycyjna wersja ruletki z pojedynczym zerem,
                                        popularna w europejskich kasynach.
                                    </p>

                                    <h5>Ruletka amerykańska</h5>
                                    <p>
                                        Odmiana z dodatkowymi polami zero oraz double zero,
                                        oferująca bardziej dynamiczną rozgrywkę.
                                    </p>

                                    <h5>Mini ruletka</h5>
                                    <p>
                                        Prostsza i szybsza wersja klasycznej ruletki
                                        z mniejszą liczbą pól.
                                    </p>

                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>