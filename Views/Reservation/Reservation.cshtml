@section Styles {
    <link rel="stylesheet" href="~/css/Reservation.css" asp-append-version="true" />
}

<div class="MainForm">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }
    <form asp-controller="Reservation" asp-action="Go" method="post">

        <div class="mb-3">
            <label class="form-label">Wybierz salę</label>
            <select id="hallSelect" name="HallId" class="form-select">
                <option value="">-- wybierz salę --</option>

                @foreach (var hall in ViewBag.Halls)
                {
                    <option value="@hall.HallId">@hall.Name</option>
                }
            </select>

            <label class="form-label">Wybierz grę</label>
            <select id="gameSelect" name="GameId" class="form-select">
                <option value="">-- najpierw wybierz salę --</option>
            </select>

            <label class="form-label">Czas</label>
            <select id="sessionSelect" name="GameSessionId" class="form-select">
                <option value="">-- najpierw wybierz grę --</option>
            </select>
        </div>

        <div class="mb-3">
            <label for="quantityInput" class="formReservation">Liczba miejsc</label>
            <input id="quantityInput" type="number" name="Quantity" class="form-control" min="1" value="1">
        </div>

        <button type="submit" class="btn btn-primary">Zarezerwuj</button>

    </form>
</div>

<script>
    const hallSelect = document.getElementById("hallSelect");
    const gameSelect = document.getElementById("gameSelect");
    const sessionSelect = document.getElementById("sessionSelect");
    const quantityInput = document.getElementById("quantityInput");

    hallSelect.addEventListener("change", function () {
        const hallId = this.value;

        gameSelect.innerHTML = '<option value="">Ładowanie...</option>';
        sessionSelect.innerHTML = '<option value="">-- najpierw wybierz grę --</option>';
        quantityInput.value = 1;
        quantityInput.removeAttribute("max");

        if (!hallId) {
            gameSelect.innerHTML = '<option value="">-- najpierw wybierz salę --</option>';
            return;
        }

        fetch(`/Reservation/GetGamesByHall?hallId=${hallId}`)
            .then(response => response.json())
            .then(games => {
                gameSelect.innerHTML = '<option value="">-- wybierz grę --</option>';

                games.forEach(game => {
                    const option = document.createElement("option");
                    option.value = game.gameId;
                    option.textContent = game.name;
                    gameSelect.appendChild(option);
                });
            });
    });

    gameSelect.addEventListener("change", function () {
        const hallId = hallSelect.value;
        const gameId = this.value;

        sessionSelect.innerHTML = '<option value="">Ładowanie...</option>';
        quantityInput.value = 1;
        quantityInput.removeAttribute("max");

        if (!hallId || !gameId) {
            sessionSelect.innerHTML = '<option value="">-- najpierw wybierz grę --</option>';
            return;
        }

        fetch(`/Reservation/GetSessionsByHallAndGame?hallId=${hallId}&gameId=${gameId}`)
            .then(response => response.json())
            .then(sessions => {
                sessionSelect.innerHTML = '<option value="">-- wybierz termin --</option>';

                sessions.forEach(session => {
                    const option = document.createElement("option");
                    option.value = session.gameSessionId;
                    option.textContent = session.text;
                    option.dataset.availableSeats = session.availableSeats;
                    sessionSelect.appendChild(option);
                });
            });
    });

    sessionSelect.addEventListener("change", function () {
        const selectedOption = this.options[this.selectedIndex];
        const availableSeats = selectedOption.dataset.availableSeats;

        if (availableSeats) {
            quantityInput.max = availableSeats;
            quantityInput.value = 1;
        } else {
            quantityInput.removeAttribute("max");
        }
    });
</script>