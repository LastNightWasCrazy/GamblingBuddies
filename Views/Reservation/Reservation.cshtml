@section Styles {
    <link rel="stylesheet" href="~/css/Reservation.css" asp-append-version="true" />
}

<div class="MainForm">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <form asp-controller="Reservation" asp-action="Go" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Wybierz salę</label>
            <select id="hallSelect" name="HallId" class="form-select" required>
                <option value="">-- wybierz salę --</option>
                @foreach (var hall in ViewBag.Halls)
                {
                    <option value="@hall.HallId">@hall.Name</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Wybierz grę</label>
            <select id="gameSelect" name="GameId" class="form-select" required disabled>
                <option value="">-- najpierw wybierz salę --</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Wybierz stół</label>
            <select id="tableSelect" name="GameTableId" class="form-select" required disabled>
                <option value="">-- najpierw wybierz grę --</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Data rezerwacji</label>
            <input id="dateInput" type="date" name="ReservationDate" class="form-control" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Godzina rozpoczęcia</label>
            <input id="timeInput" type="time" name="ReservationTime" class="form-control" required />
        </div>

        <div class="mb-3">
            <label for="quantityInput" class="formReservation">Liczba miejsc</label>
            <input id="quantityInput" type="number" name="Quantity" class="form-control" min="1" value="1" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Sposób płatności</label>

            <div class="form-check">
                <input class="form-check-input" type="radio" name="PaymentOption" value="Cash" checked>
                <label class="formReservation">
                    Zapłacę na miejscu
                </label>
            </div>

            <div class="form-check">
                <input class="form-check-input" type="radio" name="PaymentOption" value="Card">
                <label class="formReservation">
                    Zapłacę online teraz
                </label>
            </div>
        </div>

        <button type="submit" class="btn btn-primary">Zarezerwuj</button>
        </form>
</div>

<script>
    const hallSelect = document.getElementById("hallSelect");
    const gameSelect = document.getElementById("gameSelect");
    const tableSelect = document.getElementById("tableSelect");
    const quantityInput = document.getElementById("quantityInput");
    const dateInput = document.getElementById("dateInput");
    const timeInput = document.getElementById("timeInput");

    const today = new Date();
    const todayString = today.toISOString().split("T")[0];
    dateInput.min = todayString;

    hallSelect.addEventListener("change", function () {
        const hallId = this.value;

        gameSelect.disabled = true;
        tableSelect.disabled = true;

        gameSelect.innerHTML = '<option value="">Ładowanie...</option>';
        tableSelect.innerHTML = '<option value="">-- najpierw wybierz grę --</option>';

        quantityInput.value = 1;
        quantityInput.removeAttribute("max");

        if (!hallId) {
            gameSelect.innerHTML = '<option value="">-- najpierw wybierz salę --</option>';
            return;
        }

        fetch(`/Reservation/GetGamesByHall?hallId=${hallId}`)
            .then(response => response.json())
            .then(games => {
                gameSelect.innerHTML = '<option value="">-- wybierz grę --</option>';

                if (games.length === 0) {
                    gameSelect.innerHTML = '<option value="">Brak gier dla wybranej sali</option>';
                    return;
                }

                games.forEach(game => {
                    const option = document.createElement("option");
                    option.value = game.gameId;
                    option.textContent = game.name;
                    gameSelect.appendChild(option);
                });

                gameSelect.disabled = false;
            });
    });

    gameSelect.addEventListener("change", function () {
        const hallId = hallSelect.value;
        const gameId = this.value;

        tableSelect.disabled = true;
        tableSelect.innerHTML = '<option value="">Ładowanie...</option>';
        quantityInput.value = 1;
        quantityInput.removeAttribute("max");

        if (!hallId || !gameId) {
            tableSelect.innerHTML = '<option value="">-- najpierw wybierz grę --</option>';
            return;
        }

        fetch(`/Reservation/GetTablesByHallAndGame?hallId=${hallId}&gameId=${gameId}`)
            .then(response => response.json())
            .then(tables => {
                tableSelect.innerHTML = '<option value="">-- wybierz stół --</option>';

                if (tables.length === 0) {
                    tableSelect.innerHTML = '<option value="">Brak stołów dla wybranej gry</option>';
                    return;
                }

                tables.forEach(table => {
                    const option = document.createElement("option");
                    option.value = table.gameTableId;
                    option.textContent = table.text;
                    option.dataset.maxPlayers = table.maxPlayers;
                    tableSelect.appendChild(option);
                });

                tableSelect.disabled = false;
            });
    });

    tableSelect.addEventListener("change", function () {
        const selectedOption = this.options[this.selectedIndex];
        const maxPlayers = selectedOption.dataset.maxPlayers;

        if (maxPlayers) {
            quantityInput.max = maxPlayers;
            quantityInput.value = 1;
        } else {
            quantityInput.removeAttribute("max");
        }
    });

    dateInput.addEventListener("change", function () {
        const selectedDate = this.value;

        if (selectedDate === todayString) {
            const hours = String(today.getHours()).padStart(2, "0");
            const minutes = String(today.getMinutes()).padStart(2, "0");
            timeInput.min = `${hours}:${minutes}`;
        } else {
            timeInput.removeAttribute("min");
        }
    });
</script>