@model GamblingBuddies.Models.Employee

@{
    ViewData["Title"] = "Szczegóły pracownika";
    var roles = Model.SystemUser?.UserRoles?
        .Select(ur => ur.RoleDictionary?.Name)
        .Where(name => !string.IsNullOrWhiteSpace(name))
        .ToList() ?? new List<string>();
}

<div class="container mt-4">
    <h1 class="mb-4">Szczegóły pracownika</h1>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h4>Dane pracownika</h4>
            <hr />

            <p><strong>Imię:</strong> @Model.FirstName</p>
            <p><strong>Nazwisko:</strong> @Model.LastName</p>
            <p><strong>Telefon:</strong> @Model.Phone</p>
            <p><strong>Data zatrudnienia:</strong> @Model.HireDate.ToString("yyyy-MM-dd")</p>
            <p><strong>Stanowisko:</strong> @Model.Position?.Name</p>
            <p><strong>Status pracownika:</strong> @Model.Status?.Name</p>

            <h4 class="mt-4">Konto logowania</h4>
            <hr />

            <p><strong>Login:</strong> @Model.SystemUser?.Login</p>
            <p><strong>Email:</strong> @Model.SystemUser?.Email</p>
            <p>
                <strong>Konto aktywne:</strong>
                @if (Model.SystemUser?.IsActive == true)
                {
                    <span class="badge bg-success">Tak</span>
                }
                else
                {
                    <span class="badge bg-danger">Nie</span>
                }
            </p>

            <p>
                <strong>Role:</strong>
                @if (roles.Any())
                {
                    @string.Join(", ", roles)
                }
                else
                {
                    <span class="text-muted">Brak ról</span>
                }
            </p>
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Employees"
           asp-action="Edit"
           asp-route-id="@Model.EmployeeId"
           class="btn btn-warning">
            Edytuj
        </a>

        <a asp-controller="Employees" asp-action="Index" class="btn btn-secondary">
            Wróć
        </a>
    </div>
</div>